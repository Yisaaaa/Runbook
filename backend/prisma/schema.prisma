// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum RunbookPrivacy {
  PRIVATE
  PUBLIC
  SHARED
}

enum SessionStatus {
  ACTIVE
  EXPIRED
  TERMINATED
}

enum ExecutionStatus {
  SUCCESS
  FAILURE
}

model User {
  @@map("users") 
  id Int @default(autoincrement()) @id
  email String @unique
  username String
  createdAt DateTime @default(now()) @map("created_at")
  passwordHash String @map("password_hash")
  
  runbooks Runbook[]
  sessions Session[]
}

model Runbook {
  @@map("runbooks")
  id Int @default(autoincrement()) @id
  title String
  runtime String?
  content String
  privacy RunbookPrivacy @default(PRIVATE)
  shareToken String? @unique @map("share_token")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  userId Int @map("user_id")

  sessions Session[]
  user User @relation(fields: [userId], references: [id])
}

model Session {
  @@map("sessions")
  id Int @default(autoincrement()) @id
  userId Int
  runbookId Int @map("runbook_id")
  containerId String @unique @map("container_id")
  createdAt DateTime @default(now()) @map("created_at")
  status SessionStatus @default(ACTIVE)
  lastActivityAt DateTime @default(now()) @updatedAt @map("last_activity_at") 

  executionLogs ExecutionLog[]
  user User @relation(fields: [userId], references: [id])
  runbook Runbook @relation(fields: [runbookId], references: [id])
}

model ExecutionLog {
  @@map("execution_logs")
  id Int @default(autoincrement()) @id
  sessionId Int @map("session_id")
  code String
  output String
  status ExecutionStatus
  createdAt DateTime @default(now()) @map("created_at")
  
  session Session @relation(fields: [sessionId], references: [id])
}


